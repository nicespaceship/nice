{
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/www/index.html" },
    { "source": "/blueprints", "destination": "/www/blueprints.html" },
    { "source": "/about", "destination": "/www/about.html" },
    { "source": "/benduffey", "destination": "/www/benduffey.html" },
    { "source": "/privacy", "destination": "/www/privacy.html" },
    { "source": "/terms", "destination": "/www/terms.html" },
    { "source": "/accessibility", "destination": "/www/accessibility.html" }
  ],
  "redirects": [
    { "source": "/pricing", "destination": "/about#pricing", "statusCode": 301 },
    { "source": "/app", "destination": "https://nicespaceship.ai", "statusCode": 301 },
    { "source": "/app/:path*", "destination": "https://nicespaceship.ai/:path*", "statusCode": 301 },
    { "source": "/community", "destination": "https://reddit.com/r/nicespaceship", "statusCode": 302 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/www/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/www/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
