# NICE™ — Environment Variables
# Copy this to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# LLM Providers (at least one required)
GOOGLE_AI_API_KEY=your-google-ai-key          # Free from aistudio.google.com
ANTHROPIC_API_KEY=                             # Optional — premium model
OPENAI_API_KEY=                                # Optional — premium model

# Google Workspace (optional — for Gmail/Calendar/Drive MCP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT=                        # Full JSON key for domain-wide delegation

# Stripe (optional — for token purchases)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
